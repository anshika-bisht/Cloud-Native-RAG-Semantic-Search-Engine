# API Settings
PROJECT_NAME="Cloud-Native RAG Search Engine"
LOG_LEVEL="INFO"

# =========================================================================
# Mode B: Cloud-Native Database (Default)
# If using Managed Cloud PostgreSQL (Neon/Supabase)
# DATABASE_URL="postgresql+asyncpg://user:password@host.aws.neon.tech/dbname?ssl=require"
# =========================================================================
# Mode A: Local Database (Docker Compose Profile: local)
# If running `docker compose --profile local up`, use the local docker postgres:
DATABASE_URL="postgresql+asyncpg://postgres:postgres@postgres:5432/rag_db"

# =========================================================================
# Vector Store Settings
# =========================================================================
VECTOR_STORE_PROVIDER="qdrant"
QDRANT_HOST="https://<your-qdrant-host>.aws.cloud.qdrant.io"
QDRANT_PORT="6333"
QDRANT_API_KEY="your_qdrant_api_key_here"
QDRANT_COLLECTION_NAME="rag_documents"

# =========================================================================
# LLM Provider
# =========================================================================
LLM_PROVIDER="groq"
GROQ_API_KEY="your_groq_api_key_here"
GROQ_MODEL_NAME="llama3-8b-8192"

# =========================================================================
# RAG Chunking Settings
# =========================================================================
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_PERCENTAGE=0.15
MAX_FILE_SIZE_MB=50
